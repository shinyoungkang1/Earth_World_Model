      "normalizer_argv": ["python", "scripts/normalize_pa_mvp.py"],
      "trigger_argv": [
        "python",
        "scripts/download_pa_dep.py",
        "--production-only",
        "--skip-existing-production"
      ],
      "raw_manifests": ["data/raw/pa_dep/download_manifest.json"],
      "canonical_outputs": ["data/canonical/pa_mvp/production.csv"],
      "ontology_entities": ["ProductionRecord", "Well", "Permit", "RawAsset"],
      "notes": "Checks the recent PA DEP production periods and only downloads missing period IDs."

    {
      "source_id": "pa_dep_inventory",
      "status": "active",
      "refresh_strategy": "snapshot_replace",
      "default_mode": "always",
      "normalizer_argv": ["python", "scripts/normalize_pa_mvp.py"],
      "trigger_argv": ["python", "scripts/download_pa_dep.py", "--inventory-only"],
      "raw_manifests": ["data/raw/pa_dep/download_manifest.json"],
      "canonical_outputs": ["data/canonical/pa_mvp/wells.csv"],
      "ontology_entities": ["Well", "RawAsset"],
      "notes": "Small PA DEP well inventory snapshot. Re-pull when triggered."
    },
    {
      "source_id": "pa_dep_production",
      "status": "active",
      "refresh_strategy": "incremental_by_period_id",
